# ── Local development ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# PostgreSQL connection string.
# When running via docker-compose use the service name as host:
#   postgresql://jobboard:jobboard@postgres:5432/jobboard?schema=public
# When running the server directly on the host (outside Docker):
#   postgresql://jobboard:jobboard@localhost:5432/jobboard?schema=public
DATABASE_URL="postgresql://jobboard:jobboard@localhost:5432/jobboard?schema=public"

# Required for Prisma migrate dev (shadow DB). Not needed in production.
SHADOW_DATABASE_URL="postgresql://jobboard:jobboard@localhost:5432/jobboard_shadow?schema=public"

# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-string-at-least-32-chars"

JWT_EXPIRES_IN="7d"

PORT=4000

NODE_ENV="development"

# URL of the frontend (used for CORS). Adjust if your client runs elsewhere.
CLIENT_URL="http://localhost:5173"

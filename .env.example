# Root .env — consumed by docker-compose.
# Copy to .env and fill in the values before running `docker compose up`.

# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Token lifetime (optional, defaults to 7d)
JWT_EXPIRES_IN="7d"

# URL of the frontend that the API will allow via CORS.
# When running the client locally: http://localhost:5173
CLIENT_URL="http://localhost:5173"
